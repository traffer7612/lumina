# Ceitnot Protocol frontend — copy to .env

# Target chain MUST match the network of the addresses below (wagmi + reads).
# 42161 = Arbitrum One, 421614 = Arbitrum Sepolia, 8453 = Base, 11155111 = Ethereum Sepolia, 31337 = local Anvil
# VITE_CHAIN_ID=42161
#
# ── Arbitrum Sepolia (ceitnottest / DeployFullArbitrumSepolia) ────────────────
# Addresses are NOT in repo — copy from your `forge script ... --broadcast` logs.
# VITE_CHAIN_ID=421614
# VITE_ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# VITE_ENGINE_ADDRESS=0x...
# VITE_REGISTRY_ADDRESS=0x...
# VITE_GOVERNANCE_TOKEN_ADDRESS=0x...
# VITE_VE_TOKEN_ADDRESS=0x...
# VITE_GOVERNOR_ADDRESS=0x...
# VITE_TIMELOCK_ADDRESS=0x...
# VITE_CEITUSD_ADDRESS=0x...
# Legacy alias (optional): VITE_AUSD_ADDRESS=0x...
# VITE_PSM_ADDRESS=0x...
# VITE_USDC_ADDRESS=0x...
# Optional UI hints (registry is source of truth for markets):
# VITE_WSTETH_VAULT=
# VITE_WSTETH_ORACLE_RELAY=
# VITE_MOCK_WSTETH_ADDRESS=

# ── Contract addresses (required for on-chain reads/writes) ───────────────────
# Optional: implementation (not proxy) for explorers / verification workflows
# VITE_CEITNOT_ENGINE_IMPL=0x0000000000000000000000000000000000000000
# VITE_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000
# VITE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
# Governance token + vote-escrow (CeitnotToken + VeCeitnot)
# VITE_GOVERNANCE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
# VITE_VE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
# Governance + Timelock (landing + /governance; explorer links for 42161/8453/11155111)
# VITE_GOVERNOR_ADDRESS=0x0000000000000000000000000000000000000000
# VITE_TIMELOCK_ADDRESS=0x0000000000000000000000000000000000000000
# Optional external governance UI (e.g. Tally org page)
# VITE_TALLY_URL=https://www.tally.xyz/gov/<your-dao-slug>
# VITE_CEITUSD_ADDRESS=0x0000000000000000000000000000000000000000
# Legacy alias (optional): VITE_AUSD_ADDRESS=0x0000000000000000000000000000000000000000
# VITE_PSM_ADDRESS=0x0000000000000000000000000000000000000000
# VITE_USDC_ADDRESS=0x0000000000000000000000000000000000000000

# Optional RPC overrides (https://…). Dev: Vite proxies /rpc using chain + these defaults.
# VITE_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
# VITE_ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com

# VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Optional reference after script/AddWstETHMarketArbitrum.s.sol (UI reads markets from registry on-chain):
# VITE_WSTETH_VAULT=
# VITE_WSTETH_ORACLE_RELAY=
# Arbitrum: set only if market #0 uses MockERC20 wstETH (mint in UI); hide for real Lido wstETH (0x5979…)
# VITE_MOCK_WSTETH_ADDRESS=
